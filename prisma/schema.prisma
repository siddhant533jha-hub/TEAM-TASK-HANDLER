// ============================================================
// NEBULA PROJECT MANAGER - PRISMA SCHEMA
// ============================================================
// This schema defines the complete database structure for the
// Nebula Project Management application.
// 
// RELATIONSHIPS:
// - User 1:N Project (as owner)
// - User 1:N ProjectMember (many projects)
// - Project 1:N ProjectMember
// - Project 1:N Task
// - User 1:N Task (as assignee)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS - Type-safe constants for the application
// ============================================================

enum UserRole {
  ADMIN    // Full access: create/delete projects, assign tasks, manage users
  MEMBER   // Limited access: view projects, update own task status
}

enum TaskStatus {
  TODO        // Task has been created but not started
  IN_PROGRESS // Task is actively being worked on
  DONE        // Task has been completed
}

enum TaskPriority {
  LOW      // Can wait, no urgency
  MEDIUM   // Standard priority
  HIGH     // Needs attention soon
  CRITICAL // Blocker, immediate attention required
}

// ============================================================
// USER MODEL
// ============================================================
// The User model stores authentication and profile data.
// Passwords are hashed with bcrypt before storage.
// Role determines RBAC permissions throughout the app.
// ============================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   // bcrypt hashed - NEVER store plain text
  role      UserRole @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // RELATIONS
  // Projects this user owns (Admin only typically)
  ownedProjects Project[] @relation("ProjectOwner")

  // Projects this user is a member of
  memberships   ProjectMember[]

  // Tasks assigned to this user
  assignedTasks Task[] @relation("TaskAssignee")

  // Tasks created by this user
  createdTasks  Task[] @relation("TaskCreator")

  @@map("users")
}

// ============================================================
// PROJECT MODEL
// ============================================================
// Projects are the top-level containers for tasks.
// Each project has an owner (Admin) and multiple members.
// The statusSummary is computed from related tasks.
// ============================================================

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("active") // active, archived
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // RELATIONS
  // The user who created/owns this project
  ownerId String @map("owner_id")
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  // Members of this project (including the owner)
  members ProjectMember[]

  // Tasks belonging to this project
  tasks Task[]

  @@map("projects")
}

// ============================================================
// PROJECT MEMBER MODEL (Junction Table)
// ============================================================
// This junction table connects Users to Projects.
// It enables many-to-many relationship with metadata.
// Tracks when a user joined a project.
// ============================================================

model ProjectMember {
  id        String   @id @default(uuid())
  joinedAt  DateTime @default(now()) @map("joined_at")

  // RELATIONS
  projectId String @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId    String @map("user_id")
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Ensure a user can't be added to the same project twice
  @@unique([projectId, userId])
  @@map("project_members")
}

// ============================================================
// TASK MODEL
// ============================================================
// Tasks are the core work items within projects.
// They have status tracking, priority, assignment, and due dates.
// The assignee must be a member of the project.
// ============================================================

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // RELATIONS
  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // User who created this task
  creatorId String @map("creator_id")
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  // User assigned to complete this task (nullable - task can be unassigned)
  assigneeId String? @map("assignee_id")
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@map("tasks")
}
