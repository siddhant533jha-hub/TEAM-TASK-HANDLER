# ============================================================
# NEBULA PROJECT MANAGER - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local for local development
# Railway will inject these automatically in production
# ============================================================

# DATABASE
# PostgreSQL connection string
# Local: postgresql://user:password@localhost:5432/nebula_db
# Railway: ${{Postgres.DATABASE_URL}} (auto-injected)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nebula_db"

# AUTHENTICATION
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# FRONTEND
NEXT_PUBLIC_APP_URL="http://localhost:3000"
